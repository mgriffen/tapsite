{
  "name": "tapsite",
  "version": "4.5.1",
  "mcpName": "io.github.mgriffen/tapsite",
  "description": "MCP server for web intelligence extraction — design systems, accessibility audits, competitive analysis, and migration prep",
  "main": "src/cli.js",
  "bin": {
    "tapsite": "src/server.js",
    "tapsite-cli": "src/cli.js"
  },
  "files": [
    "src",
    "LICENSE",
    "README.md"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "start": "node src/server.js",
    "login": "node src/cli.js login",
    "inspect": "node src/cli.js inspect",
    "prepublishOnly": "npm test",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "browser",
    "playwright",
    "web-intelligence",
    "design-system",
    "accessibility",
    "web-scraping",
    "claude",
    "ai",
    "design-tokens",
    "ui-analysis"
  ],
  "author": "mgriffen",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mgriffen/tapsite.git"
  },
  "license": "MIT",
  "type": "commonjs",
  "bugs": {
    "url": "https://github.com/mgriffen/tapsite/issues"
  },
  "homepage": "https://github.com/mgriffen/tapsite#readme",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1",
    "playwright": "^1.58.2",
    "playwright-extra": "^4.3.6",
    "puppeteer-extra-plugin-stealth": "^2.11.2"
  },
  "devDependencies": {
    "vitest": "^4.1.0"
  }
}
